{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "sortImports": {
    "groups": [
      "type-import",
      ["value-builtin", "value-external"],
      "type-internal",
      "value-internal",
      ["type-parent", "type-sibling", "type-index"],
      ["value-parent", "value-sibling", "value-index"],
      "unknown"
    ]
  },
  "sortPackageJson": {
    "sortScripts": true
  },
  "ignorePatterns": [
    ".wrangler/**",
    "coverage/**",
    "dist/**",
    "build/**",
    "docs/.vitepress/**",
    "functions/*.js",
    "functions/*.js.map",
    "pnpm-lock.yaml",
    "CHANGELOG.md",
    "worker-configuration.d.ts"
  ]
}
