{
  "name": "turborepo-remote-cache-cf",
  "version": "4.0.0",
  "private": true,
  "description": "An implementation of the turborepo-remote-cache server custom made for Cloudflare Workers",
  "keywords": [
    "cloudflare-r2",
    "cloudflare-workers",
    "remote-caching",
    "serverless",
    "turborepo",
    "vercel"
  ],
  "homepage": "https://github.com/AdiRishi/turborepo-remote-cache-cloudflare",
  "bugs": {
    "url": "https://github.com/AdiRishi/turborepo-remote-cache-cloudflare/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Adishwar Rishi",
    "email": "adiswa123@gmail.com",
    "url": "https://github.com/AdiRishi"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AdiRishi/turborepo-remote-cache-cloudflare.git"
  },
  "type": "module",
  "scripts": {
    "build": "vite build",
    "cf-typegen": "wrangler types",
    "deploy": "wrangler deploy",
    "dev": "vite",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:preview": "vitepress preview docs",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint --quiet && oxfmt --check .",
    "lint:fix": "oxlint --fix",
    "preview": "vite preview",
    "test": "vitest run --coverage",
    "test:ui": "vitest --coverage --ui",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/valibot-validator": "^0.6.1",
    "hono": "^4.12.25",
    "valibot": "^1.4.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@cloudflare/vite-plugin": "^1.40.2",
    "@cloudflare/vitest-pool-workers": "^0.16.15",
    "@vitest/coverage-istanbul": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "miniflare": "^4.20260611.0",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "oxlint-tsgolint": "^0.23.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitepress": "2.0.0-alpha.16",
    "vitest": "^4.1.8",
    "wrangler": "^4.100.0"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@11.6.0",
  "readme": "README.md"
}
